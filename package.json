{
  "name": "ssh-cli-sessions",
  "license": "MIT",
  "version": "1.0.17",
  "description": "A Linux-first CLI SSH session manager with named persistent shells and session logs.",
  "type": "module",
  "bin": {
    "ssh-cli": "build/index.js"
  },
  "scripts": {
    "prepare": "npm run build",
    "build": "node ./scripts/build.mjs",
    "typecheck": "tsc --noEmit",
    "test": "cross-env SSH_CLI_DISABLE_MAIN=1 vitest --run --exclude '.claude/worktrees/**'",
    "test:watch": "cross-env SSH_CLI_DISABLE_MAIN=1 vitest --exclude '.claude/worktrees/**'",
    "coverage": "cross-env SSH_CLI_DISABLE_MAIN=1 vitest --run --coverage --exclude '.claude/worktrees/**'"
  },
  "files": [
    "build"
  ],
  "dependencies": {
    "ssh2": "^1.17.0",
    "yaml": "^2.8.4",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "@types/ssh2": "^1.15.5",
    "cross-env": "^7.0.3",
    "shx": "^0.4.0",
    "testcontainers": "^11.7.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.20.6",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  },
  "homepage": "https://github.com/fryjustinc/ssh-cli-sessions#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/fryjustinc/ssh-cli-sessions.git"
  },
  "bugs": {
    "url": "https://github.com/fryjustinc/ssh-cli-sessions/issues"
  },
  "keywords": [
    "ssh",
    "cli",
    "linux",
    "session-manager",
    "persistent-shell",
    "remote",
    "automation",
    "typescript"
  ],
  "author": "kryonas",
  "engines": {
    "node": ">=18"
  }
}
